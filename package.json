{
  "name": "ng-ftd",
  "version": "0.0.0",
  "main": "firebase-index.js",
  "engines": {
    "node": "10.x.x"
  },
  "scripts": {
    "ng": "ng",
    "ng:start": "ng serve --host 0.0.0.0",
    "start": "node dist/server/main.js",
    "build": "ng build",
    "build:production": "ng build --configuration production --output-hashing bundles",
    "build:call-center": "ng build --configuration call-center --output-hashing bundles",
    "build:sandbox": "ng build --configuration sandbox --output-hashing bundles",
    "build:multi-country-development": "ng build",
    "amp:col": "cp -R countries/colombia/amp/* dist/browser && npm run cloud-build:col && npm run enviroment-develop-file-devops:col && npm run enviroments-file-devops:col",
    "cloud-build:col": "cp -R project-assets/basic/cloudbuild.yaml dist/browser/ && cp -R project-assets/basic/cloudbuild.post.yaml dist/browser/",
    "enviroment-develop-file-devops:col": "cp -R project-assets/basic/environments/enviromentDevelop.yaml dist/browser",
    "enviroments-file-devops:col": "cp -R project-assets/basic/environments/environments.yaml dist/browser",
    "sitemaps:col": "cp -r countries/colombia/sitemaps/* dist/browser",
    "sitemaps:ven": "cp -r countries/venezuela/sitemaps/* dist/browser",
    "ios-assets": "cp project-assets/ios-assets/apple-app-site-association dist/browser",
    "prepare-deploy": "cp project-assets/basic/browser/app.yaml dist/browser/ && npm run ios-assets && cp countries/colombia-staging/sitemaps/robots.txt dist/browser/",
    "deploy:develop": "npm run prepare-deploy && cd dist/browser && gcloud app deploy --no-promote --version",
    "deploy:production:col": "npm run prepare-deploy && npm run sitemaps:col && cd dist/browser && gcloud app deploy --no-promote --version",
    "deploy:production:ven": "npm run prepare-deploy && npm run sitemaps:ven && cd dist/browser && gcloud app deploy --no-promote --version",
    "serve": "ng serve --host 0.0.0.0",
    "serve:https": "ng serve --ssl true --ssl-key localhost-key.pem --ssl-cert localhost.pem",
    "ssr:build:develop": "npm run build:multi-country-development && ng run ng-ftd:server",
    "ssr:build:production": "rimraf dist && npm run build:production && ng run ng-ftd:server:production",
    "ssr:build:sandbox": "npm run build:sandbox && ng run ng-ftd:server:production",
    "ssr:sitemaps:col": "cp -r countries/colombia/sitemaps/* deployment-env/dist/browser",
    "ssr:sitemaps:col:staging": "cp -r countries/colombia-staging/sitemaps/* deployment-env/dist/browser",
    "ssr:sitemaps:ven": "cp -r countries/venezuela/sitemaps/* deployment-env/dist/browser",
    "ssr:ios-assets": "cp project-assets/ios-assets/apple-app-site-association deployment-env/dist/browser",
    "ssr:prepare-deploy": "cp project-assets/basic/package.json deployment-env/ && cp project-assets/basic/ssr/production/app.yaml deployment-env/ && npm run ssr:ios-assets && cp service-worker.js deployment-env/dist/browser",
    "ssr:prepare-deploy:staging": "cp project-assets/basic/package.json deployment-env/ && cp project-assets/basic/ssr/app.yaml deployment-env/ && npm run ssr:ios-assets && cp service-worker.js deployment-env/dist/browser",
    "ssr:deploy:develop": "rm -rf deployment-env && mkdir deployment-env && cp -R dist deployment-env/dist && npm run ssr:prepare-deploy && cp service-worker.js deployment-env/dist/browser && cd deployment-env && gcloud app deploy --no-promote --version",
    "ssr:deploy:production:col": "rm -rf deployment-env && mkdir deployment-env && cp -R dist deployment-env/dist && npm run ssr:prepare-deploy && npm run ssr:sitemaps:col && cd deployment-env && gcloud app deploy --no-promote --version",
    "ssr:deploy:production:col:staging": "rm -rf deployment-env && mkdir deployment-env && cp -R dist deployment-env/dist && npm run ssr:prepare-deploy:staging && npm run ssr:sitemaps:col:staging && cd deployment-env && gcloud app deploy --no-promote --version",
    "ssr:deploy:production:ven": "rm -rf deployment-env && mkdir deployment-env && cp -R dist deployment-env/dist && npm run ssr:prepare-deploy && npm run ssr:sitemaps:ven && cd deployment-env && gcloud app deploy --no-promote --version",
    "ssr:development:server": "ng run ng-ftd:serve-ssr",
    "ssr:serve": "node dist/server/main.js",
    "build-and-deploy:call-center": "npm run build:call-center && npm run deploy:develop",
    "build-and-deploy:ssr:develop": "npm run ssr:build:develop && npm run ssr:deploy:develop",
    "build-and-deploy:ssr:production:col": "npm run ssr:build:production && npm run ssr:deploy:production:col",
    "build-and-deploy:ssr:production:col:staging": "npm run ssr:build:production && npm run ssr:deploy:production:col:staging",
    "build-and-deploy:ssr:production:ven": "npm run ssr:build:production && npm run ssr:deploy:production:ven",
    "deploy-col": "npm run build-and-deploy:ssr:production:col:staging",
    "deploy-ven": "npm run build-and-deploy:ssr:production:ven",
    "build-ven": "npm run ssr:build:production",
    "deploy-col:cloud-run": "./scripts/deploy-staging-local.sh",
    "deploy-col:cloud-run:production": "./scripts/deploy-production-local.sh",
    "docker:build": "docker build -t ftd-web-staging:local -f Dockerfile .",
    "docker:run": "docker run -p 8080:8080 --env PORT=8080 ftd-web-staging:local",
    "docker:test": "npm run docker:build && npm run docker:run",
    "lint": "ng lint",
    "lint-fix": "eslint --fix",
    "html-lint": "npx htmlhint \"**/*.html\"",
    "test": "ng test",
    "e2e": "ng e2e",
    "analyze": "webpack-bundle-analyzer dist/browser/stats-es2015.json",
    "change-project": "gcloud config set project",
    "node-memory-mac": "export NODE_OPTIONS=--max_old_space_size=6144",
    "node-memory-win": "set NODE_OPTIONS=--max_old_space_size=6144",
    "cloudbuild": "gcloud builds submit --config=cloudbuild.yaml .",
    "cloudbuild:production:post": "gcloud builds submit --config=project-assets/basic/cloudbuild.post.yaml .",
    "environments": "gcloud builds submit --config=project-assets/basic/environments/environments.yaml .",
    "enviromentDevelop": "gcloud builds submit --config=project-assets/basic/environments/enviromentDevelop.yaml .",
    "cloudlbuild:image": "gcloud builds submit --tag gcr.io/web-farmatodo/ubuntu-angular",
    "postinstall": "ngcc",
    "sonar": "sonar-scanner",
    "preinstall": "npx npm-force-resolutions"
  },
  "husky": {},
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix"
    ]
  },
  "resolutions": {
    "json5": "2.2.3",
    "lodash": "4.18.0",
